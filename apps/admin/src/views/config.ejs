<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Config — sats.fast</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #0d1117; color: #c9d1d9; min-height: 100vh; }
    nav { background: #161b22; border-bottom: 1px solid #30363d; padding: 1rem 2rem; display: flex; align-items: center; gap: 2rem; }
    nav .brand { font-size: 1.25rem; font-weight: 700; color: #f0b90b; text-decoration: none; }
    nav a { color: #8b949e; text-decoration: none; font-size: 0.9rem; }
    nav a:hover { color: #c9d1d9; }
    .container { max-width: 800px; margin: 2rem auto; padding: 0 2rem; }
    h1 { color: #f0f6fc; margin-bottom: 1.5rem; }
    .card { background: #161b22; border: 1px solid #30363d; border-radius: 8px; padding: 1.5rem; margin-bottom: 1rem; }
    .form-row { display: flex; gap: 1rem; align-items: end; margin-bottom: 1rem; }
    .form-group { flex: 1; }
    .form-group label { display: block; margin-bottom: 0.4rem; font-size: 0.9rem; color: #8b949e; }
    .form-group input { width: 100%; background: #0d1117; border: 1px solid #30363d; color: #c9d1d9; padding: 0.5rem 0.75rem; border-radius: 6px; font-size: 0.9rem; }
    .btn { padding: 0.5rem 1.25rem; border: none; border-radius: 6px; background: #238636; color: white; font-size: 0.9rem; cursor: pointer; }
    .btn:hover { background: #2ea043; }
    table { width: 100%; border-collapse: collapse; }
    th, td { padding: 0.5rem 1rem; text-align: left; border-bottom: 1px solid #30363d; }
    th { color: #8b949e; font-size: 0.85rem; }
    .footer { text-align: center; color: #484f58; font-size: 0.8rem; padding: 2rem; margin-top: 2rem; border-top: 1px solid #30363d; }
  </style>
</head>
<body>
  <nav>
    <a href="/" class="brand">⚡ sats.fast</a>
    <a href="/">Dashboard</a>
    <a href="/users">Users</a>
    <a href="/approvals">Approvals</a>
    <a href="/receipts">Receipts</a>
    <a href="/config">Config</a>
    <a href="/logout" style="margin-left:auto;">Logout</a>
  </nav>
  <div class="container">
    <h1>⚙️ Configuration</h1>

    <div class="card">
      <h2 style="color:#f0f6fc;margin-bottom:1rem;">Current Config</h2>
      <table>
        <thead><tr><th>Key</th><th>Value</th></tr></thead>
        <tbody>
          <% Object.keys(config).forEach(function(k) { %>
          <tr><td><%= k %></td><td><%= config[k] %></td></tr>
          <% }) %>
          <% if (Object.keys(config).length === 0) { %>
          <tr><td colspan="2" style="color:#8b949e;">No configuration entries yet.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <div class="card">
      <h2 style="color:#f0f6fc;margin-bottom:1rem;">Add / Update</h2>
      <form method="POST" action="/config">
        <div class="form-row">
          <div class="form-group">
            <label>Key</label>
            <input type="text" name="key" required placeholder="e.g. welcome_message">
          </div>
          <div class="form-group">
            <label>Value</label>
            <input type="text" name="value" required placeholder="e.g. Hello!">
          </div>
          <button type="submit" class="btn">Save</button>
        </div>
      </form>
    </div>
  </div>
  <div class="footer">sats.fast admin — Demo-grade security. Add proper auth before production use.</div>
</body>
</html>
