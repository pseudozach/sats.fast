<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'sats.fast Admin' %></title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #0d1117; color: #c9d1d9; min-height: 100vh; }
    nav { background: #161b22; border-bottom: 1px solid #30363d; padding: 1rem 2rem; display: flex; align-items: center; gap: 2rem; }
    nav .brand { font-size: 1.25rem; font-weight: 700; color: #f0b90b; text-decoration: none; }
    nav a { color: #8b949e; text-decoration: none; font-size: 0.9rem; }
    nav a:hover { color: #c9d1d9; }
    .container { max-width: 1200px; margin: 2rem auto; padding: 0 2rem; }
    h1 { color: #f0f6fc; margin-bottom: 1.5rem; }
    .card { background: #161b22; border: 1px solid #30363d; border-radius: 8px; padding: 1.5rem; margin-bottom: 1rem; }
    .card h2 { color: #f0f6fc; font-size: 1.1rem; margin-bottom: 0.5rem; }
    .card .value { font-size: 2rem; font-weight: 700; color: #f0b90b; }
    .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
    table { width: 100%; border-collapse: collapse; }
    th, td { padding: 0.75rem 1rem; text-align: left; border-bottom: 1px solid #30363d; }
    th { color: #8b949e; font-size: 0.85rem; text-transform: uppercase; }
    td { font-size: 0.9rem; }
    .btn { display: inline-block; padding: 0.4rem 1rem; border-radius: 6px; border: none; cursor: pointer; font-size: 0.85rem; text-decoration: none; }
    .btn-primary { background: #238636; color: white; }
    .btn-danger { background: #da3633; color: white; }
    .btn-small { padding: 0.25rem 0.6rem; font-size: 0.8rem; }
    input, select { background: #0d1117; border: 1px solid #30363d; color: #c9d1d9; padding: 0.5rem 0.75rem; border-radius: 6px; font-size: 0.9rem; }
    input:focus, select:focus { outline: none; border-color: #388bfd; }
    .footer { text-align: center; color: #484f58; font-size: 0.8rem; padding: 2rem; margin-top: 2rem; border-top: 1px solid #30363d; }
    .badge { display: inline-block; padding: 0.15rem 0.5rem; border-radius: 10px; font-size: 0.75rem; font-weight: 600; }
    .badge-pending { background: #9e6a03; color: #f0b90b; }
    .badge-approved { background: #238636; color: #56d364; }
    .badge-denied { background: #da3633; color: #f85149; }
    .error { background: #da363322; border: 1px solid #da3633; color: #f85149; padding: 0.75rem 1rem; border-radius: 6px; margin-bottom: 1rem; }
  </style>
</head>
<body>
  <nav>
    <a href="/" class="brand">⚡ sats.fast</a>
    <a href="/">Dashboard</a>
    <a href="/users">Users</a>
    <a href="/approvals">Approvals</a>
    <a href="/receipts">Receipts</a>
    <a href="/config">Config</a>
    <a href="/health">Health</a>
    <a href="/logout" style="margin-left:auto;">Logout</a>
  </nav>
  <div class="container">
    <%- body %>
  </div>
  <div class="footer">
    sats.fast admin panel — Demo-grade security. Add proper auth before production use.
  </div>
</body>
</html>
