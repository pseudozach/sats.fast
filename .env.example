# Required
TELEGRAM_BOT_TOKEN=          # from @BotFather
MASTER_ENCRYPTION_KEY=        # 64-char hex, generate with: openssl rand -hex 32
BREEZ_API_KEY=                # free from breez.technology/request-api-key
ADMIN_USERNAME=               # set during install.sh
ADMIN_PASSWORD_HASH=          # bcrypt hash, set during install.sh

# Optional defaults (users can override per-user)
DEFAULT_AI_PROVIDER=anthropic  # 'anthropic' or 'openai'
DEFAULT_AI_MODEL=claude-sonnet-4-20250514
DEFAULT_ANTHROPIC_KEY=        # optional fallback
DEFAULT_OPENAI_KEY=           # optional fallback

# App
NODE_ENV=production
PORT=3000                     # admin panel port
DATA_DIR=./data               # Breez working dirs live here
DATABASE_URL=./data/sats.db
SESSION_SECRET=               # generate with: openssl rand -hex 32
